generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id                 String              @id @default(cuid())
  name               String?
  email              String              @unique
  emailVerified      DateTime?
  image              String?
  password           String?
  phone              String?
  role               UserRole            @default(CLIENT)
  walletBalance      Float               @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  studentProfile     Json?
  accounts           Account[]
  blogComments       BlogComment[]
  blogPosts          BlogPost[]          @relation("BlogAuthor")
  jobs               Job[]
  orders             Order[]
  sessions           Session[]
  studyMaterials     StudyMaterial[]
  subscriptions      Subscription[]
  tutorSessions      TutorSession[]
  assessments        Assessment[]
  consents           UserConsent[]
  vendorProfile      VendorProfile?
  walletTransactions WalletTransaction[]
}

model VendorProfile {
  id             String          @id @default(cuid())
  userId         String          @unique
  storeName      String
  storeSlug      String          @unique
  status         VendorStatus    @default(PENDING)
  adminNotes     String?
  totalEarnings  Float           @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  address        String?
  fullName       String?
  idProofUrl     String?
  resumeUrl      String?
  description    String?
  portfolioUrl   String?
  jobs           Job[]
  payoutRequests PayoutRequest[]
  services       Service[]
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String
  planType  String   @default("Tutor_Monthly")
  status    String   @default("ACTIVE")
  amount    Float
  reference String   @unique
  startsAt  DateTime @default(now())
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StudyMaterial {
  id            String   @id @default(cuid())
  userId        String
  title         String
  fileUrl       String
  fileType      String
  extractedText String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TutorSession {
  id               String   @id @default(cuid())
  userId           String
  messages         Json
  learningPatterns Json?
  lastActivity     DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Assessment {
  id               String   @id @default(cuid())
  userId           String
  materialId       String?
  topic            String
  score            Float
  totalQuestions   Int
  correctAnswers   Int
  questions        Json     // Stores the questions asked
  answers          Json     // Stores the student's answers
  aiFeedback       String?
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Service {
  id                String                @id @default(cuid())
  name              String
  slug              String                @unique
  description       String
  category          ServiceCategory
  basePrice         Float
  expressMultiplier Float                 @default(1.5)
  isActive          Boolean               @default(true)
  formSchema        Json?
  aiPrompt          String?
  autonomyLevel     AiAutonomy            @default(AI_PLUS_HUMAN)
  turnaroundHours   Int                   @default(24)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  approvalStatus    ServiceApprovalStatus @default(APPROVED)
  vendorId          String?
  datasets          Dataset[]
  jobs              Job[]
  vendor            VendorProfile?        @relation(fields: [vendorId], references: [id])
}

model Job {
  id               String         @id @default(cuid())
  userId           String
  serviceId        String
  title            String
  description      String
  formData         Json?
  status           JobStatus      @default(SUBMITTED)
  priority         Priority       @default(NORMAL)
  attachments      String[]
  aiOutput         String?
  aiConfidence     Float?
  adminNotes       String?
  complexity       Complexity     @default(MEDIUM)
  dueAt            DateTime?
  completedAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  fundsInEscrow    Boolean        @default(false)
  vendorId         String?
  aiScore          Float?
  grammarScore     Float?
  isPlagiarismFree Boolean        @default(false)
  plagiarismScore  Float?
  service          Service        @relation(fields: [serviceId], references: [id])
  user             User           @relation(fields: [userId], references: [id])
  vendor           VendorProfile? @relation(fields: [vendorId], references: [id])
  order            Order?
  revisions        Revision[]
}

model Revision {
  id        String   @id @default(cuid())
  jobId     String
  reason    String
  createdAt DateTime @default(now())
  job       Job      @relation(fields: [jobId], references: [id])
}

model Order {
  id        String        @id @default(cuid())
  userId    String
  jobId     String        @unique
  amount    Float
  currency  String        @default("NGN")
  status    PaymentStatus @default(PENDING)
  gateway   String?
  reference String?       @unique
  metadata  Json?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  couponId  String?
  discount  Float         @default(0)
  total     Float
  proofUrl  String?
  coupon    Coupon?       @relation(fields: [couponId], references: [id])
  job       Job           @relation(fields: [jobId], references: [id])
  user      User          @relation(fields: [userId], references: [id])
}

model Coupon {
  id            String    @id @default(cuid())
  code          String    @unique
  discountType  String
  discountValue Float
  minAmount     Float     @default(0)
  expiresAt     DateTime?
  maxUses       Int?
  usedCount     Int       @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  isFeatured    Boolean   @default(false)
  orders        Order[]
}

model SiteSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Dataset {
  id        String   @id @default(cuid())
  name      String
  fileUrl   String?
  fileType  String?
  content   String?
  size      Int?
  serviceId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  service   Service? @relation(fields: [serviceId], references: [id])
}

model Page {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     Json?
  metaTitle   String?
  metaDesc    String?
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BlogPost {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  excerpt     String?
  content     String?
  coverImage  String?
  isPublished Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  authorId    String
  categoryId  String?
  metaDesc    String?
  metaTitle   String?
  comments    BlogComment[]
  author      User          @relation("BlogAuthor", fields: [authorId], references: [id])
  category    BlogCategory? @relation(fields: [categoryId], references: [id])
}

model BlogCategory {
  id    String     @id @default(cuid())
  name  String     @unique
  slug  String     @unique
  icon  String?
  posts BlogPost[]
}

model BlogComment {
  id        String   @id @default(cuid())
  content   String
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  actor     String
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())
}

model WalletTransaction {
  id           String                  @id @default(cuid())
  userId       String
  type         String
  amount       Float
  balanceAfter Float
  reference    String                  @unique
  description  String?
  createdAt    DateTime                @default(now())
  proofUrl     String?
  status       WalletTransactionStatus @default(SUCCESS)
  gateway      String?
  user         User                    @relation(fields: [userId], references: [id])
}

model UserConsent {
  id           String   @id @default(cuid())
  userId       String?
  ipAddress    String?
  consentType  String
  browserAgent String?
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id])
}

model PayoutRequest {
  id            String        @id @default(cuid())
  vendorId      String
  amount        Float
  status        PayoutStatus  @default(PENDING)
  bankName      String
  accountNumber String
  accountName   String
  adminNotes    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  vendor        VendorProfile @relation(fields: [vendorId], references: [id])
}

enum UserRole {
  CLIENT
  ADMIN
  SUPER_ADMIN
  AGENT
  VENDOR
}

enum VendorStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum ServiceApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  REJECTED
}

enum ServiceCategory {
  ACADEMIC
  GOVERNMENT
  DIGITAL_BUSINESS
  AI_ENHANCED
  TYPING
  VA
}

enum JobStatus {
  SUBMITTED
  IN_PROGRESS
  REVIEW
  COMPLETED
  REVISION_REQUESTED
  CANCELLED
}

enum Priority {
  NORMAL
  EXPRESS
}

enum Complexity {
  LOW
  MEDIUM
  HIGH
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum AiAutonomy {
  AI_ONLY
  AI_PLUS_HUMAN
  HUMAN_ONLY
}

enum WalletTransactionStatus {
  PENDING
  SUCCESS
  FAILED
}
